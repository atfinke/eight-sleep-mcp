# Provide either a live access token or full password-grant credentials.
# Access tokens are convenient for local prototyping but they expire.
EIGHT_SLEEP_ACCESS_TOKEN=

# Password grant credentials from your own captured app traffic.
EIGHT_SLEEP_EMAIL=
EIGHT_SLEEP_PASSWORD=
EIGHT_SLEEP_CLIENT_ID=
EIGHT_SLEEP_CLIENT_SECRET=

# Optional. If omitted, the server resolves these from /users/me and the auth response.
EIGHT_SLEEP_USER_ID=
EIGHT_SLEEP_CLIENT_DEVICE_ID=

# Compatibility headers observed in the iOS app capture.
EIGHT_SLEEP_CLIENT_APP_VERSION=7.46.0
EIGHT_SLEEP_USER_AGENT=iOS App - 7.46.0/58 - iPhone18,1 - iOS 26.4
EIGHT_SLEEP_ACCEPT_LANGUAGE=en-US;q=1.0

# Default query flag for temperature writes.
EIGHT_SLEEP_IGNORE_DEVICE_ERRORS_DEFAULT=false

# Request timeout for outbound Eight Sleep API calls.
EIGHT_SLEEP_REQUEST_TIMEOUT_MS=15000
