{
  "name": "eight-sleep-mcp",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Typed MCP server for Eight Sleep based on observed 2026 mobile API traffic.",
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "package:mcpb": "npm run build && node scripts/package-mcpb.mjs",
    "start": "node dist/index.js",
    "test": "tsx --test src/**/*.test.ts"
  },
  "engines": {
    "node": ">=20.18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "dotenv": "17.3.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "2.1.2",
    "@types/node": "25.5.0",
    "tsx": "4.21.0",
    "typescript": "6.0.2"
  }
}
